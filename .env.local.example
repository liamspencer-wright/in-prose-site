NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ISBNDB_API_KEY=your-isbndb-api-key

# SEO measurement (optional — see docs/SEO.md)
# Verification meta tags injected from src/app/layout.tsx
GOOGLE_SITE_VERIFICATION=your-google-site-verification
BING_SITE_VERIFICATION=your-bing-msvalidate-code

# IndexNow — 8-128 char hex/numeric. Served at https://inprose.co.uk/<key>.txt
# Generate with: openssl rand -hex 32
INDEXNOW_KEY=your-indexnow-key
